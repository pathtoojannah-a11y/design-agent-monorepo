{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeneratedBuildSpec",
  "type": "object",
  "required": ["project", "selectedSections", "sectionRationale", "globalVisualDirection", "brandAdaptation", "copyDirection", "implementationPrompt", "constraints", "primaryCategories", "expandedCategories", "questionsAsked", "confidenceSummary"],
  "properties": {
    "project": { "type": "object" },
    "selectedSections": { "type": "array", "items": { "type": "object" } },
    "sectionRationale": { "type": "array", "items": { "type": "string" } },
    "globalVisualDirection": { "type": "object" },
    "brandAdaptation": { "type": "object" },
    "copyDirection": { "type": "object" },
    "implementationPrompt": { "type": "string" },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "componentRecipes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "sourceName": { "type": "string" },
          "sourceCategory": { "type": "string" },
          "itemKind": { "type": "string" },
          "targetStack": { "type": "object" },
          "destinationPaths": { "type": "object" },
          "install": { "type": "object" },
          "supportFiles": { "type": "array", "items": { "type": "string" } },
          "adaptationNotes": { "type": "array", "items": { "type": "string" } },
          "promptRecipe": { "type": ["object", "null"] },
          "resolvedPromptRecipe": { "type": ["object", "null"] },
          "completenessStatus": { "type": ["string", "null"] },
          "missingFields": { "type": "array", "items": { "type": "string" } },
          "provenance": { "type": ["object", "null"] }
        }
      }
    },
    "cacheHealth": { "type": ["object", "null"] },
    "coverageWarnings": { "type": "array", "items": { "type": "object" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "primaryCategories": { "type": "array", "items": { "type": "string" } },
    "expandedCategories": { "type": "array", "items": { "type": "string" } },
    "questionsAsked": { "type": "array", "items": { "type": "object" } },
    "confidenceSummary": { "type": "object" }
  }
}
